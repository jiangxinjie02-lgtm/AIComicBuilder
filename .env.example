# App
DATABASE_URL=file:./data/aicomic.db
UPLOAD_DIR=./uploads

# JimAPI / ToAPIs-compatible video provider
JIMAPI_BASE_URL=https://www.jimapi.com/v1
JIMAPI_API_KEY=
JIMAPI_VIDEO_MODEL=viduq3-turbo
# These may be either paths under JIMAPI_BASE_URL or full URLs from the supplier.
JIMAPI_VIDEO_ENDPOINT_PATH=/videos/generations
JIMAPI_UPLOAD_IMAGE_ENDPOINT_PATH=/uploads/images
